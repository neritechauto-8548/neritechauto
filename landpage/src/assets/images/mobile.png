<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="mobileBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a84ff;stop-opacity:0.15" />
      <stop offset="100%" style="stop-color:#63b4ff;stop-opacity:0.25" />
    </linearGradient>
    <linearGradient id="screenGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#1a3a5c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f1c2e;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#0f1c2e"/>
  <rect width="800" height="600" fill="url(#mobileBg)"/>
  
  <!-- Phone Frame -->
  <rect x="250" y="50" width="300" height="500" rx="30" fill="#1a1a1a" stroke="#333" stroke-width="8"/>
  <rect x="265" y="65" width="270" height="470" rx="20" fill="url(#screenGrad)"/>
  
  <!-- Status Bar -->
  <rect x="275" y="75" width="250" height="25" fill="rgba(0,0,0,0.3)"/>
  <text x="290" y="93" font-family="Arial, sans-serif" font-size="12" fill="#fff">9:41</text>
  <text x="495" y="93" font-family="Arial, sans-serif" font-size="12" fill="#fff">📶 🔋</text>
  
  <!-- Header -->
  <rect x="275" y="110" width="250" height="50" fill="rgba(10,132,255,0.1)"/>
  <text x="400" y="140" font-family="Arial, sans-serif" font-size="18" fill="#fff" font-weight="bold" text-anchor="middle">NeriTech</text>
  
  <!-- Quick Stats Cards -->
  <rect x="285" y="175" width="110" height="80" rx="10" fill="rgba(10,132,255,0.3)"/>
  <text x="340" y="205" font-family="Arial, sans-serif" font-size="20" fill="#0a84ff" font-weight="bold" text-anchor="middle">12</text>
  <text x="340" y="225" font-family="Arial, sans-serif" font-size="11" fill="#8b9dc3" text-anchor="middle">OS Ativas</text>
  
  <rect x="405" y="175" width="110" height="80" rx="10" fill="rgba(99,180,255,0.3)"/>
  <text x="460" y="205" font-family="Arial, sans-serif" font-size="20" fill="#63b4ff" font-weight="bold" text-anchor="middle">5</text>
  <text x="460" y="225" font-family="Arial, sans-serif" font-size="11" fill="#8b9dc3" text-anchor="middle">Pendentes</text>
  
  <!-- Service Orders List -->
  <rect x="285" y="270" width="230" height="60" rx="8" fill="rgba(255,255,255,0.05)"/>
  <circle cx="305" cy="300" r="15" fill="#0a84ff"/>
  <text x="310" y="305" font-family="Arial, sans-serif" font-size="14" fill="#fff" font-weight="bold" text-anchor="middle">🚗</text>
  <text x="335" y="295" font-family="Arial, sans-serif" font-size="13" fill="#fff" font-weight="600">OS #1234</text>
  <text x="335" y="312" font-family="Arial, sans-serif" font-size="10" fill="#8b9dc3">Honda Civic - Em andamento</text>
  
  <rect x="285" y="340" width="230" height="60" rx="8" fill="rgba(255,255,255,0.05)"/>
  <circle cx="305" cy="370" r="15" fill="#63b4ff"/>
  <text x="310" y="375" font-family="Arial, sans-serif" font-size="14" fill="#fff" font-weight="bold" text-anchor="middle">🔧</text>
  <text x="335" y="365" font-family="Arial, sans-serif" font-size="13" fill="#fff" font-weight="600">OS #1235</text>
  <text x="335" y="382" font-family="Arial, sans-serif" font-size="10" fill="#8b9dc3">Toyota Corolla - Aguardando</text>
  
  <rect x="285" y="410" width="230" height="60" rx="8" fill="rgba(255,255,255,0.05)"/>
  <circle cx="305" cy="440" r="15" fill="rgba(10,132,255,0.5)"/>
  <text x="310" y="445" font-family="Arial, sans-serif" font-size="14" fill="#fff" font-weight="bold" text-anchor="middle">⚙️</text>
  <text x="335" y="435" font-family="Arial, sans-serif" font-size="13" fill="#fff" font-weight="600">OS #1236</text>
  <text x="335" y="452" font-family="Arial, sans-serif" font-size="10" fill="#8b9dc3">Ford Focus - Diagnóstico</text>
  
  <!-- Bottom Nav -->
  <rect x="275" y="490" width="250" height="35" fill="rgba(0,0,0,0.5)"/>
  <text x="315" y="513" font-family="Arial, sans-serif" font-size="18" fill="#0a84ff">🏠</text>
  <text x="375" y="513" font-family="Arial, sans-serif" font-size="18" fill="#8b9dc3">📋</text>
  <text x="435" y="513" font-family="Arial, sans-serif" font-size="18" fill="#8b9dc3">👤</text>
  <text x="495" y="513" font-family="Arial, sans-serif" font-size="18" fill="#8b9dc3">⚙️</text>
</svg>
