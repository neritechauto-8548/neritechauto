                    ($P{TELEFONE_EMPRESA} != null && !$P{TELEFONE_EMPRESA}.isEmpty() ? "Tel: " + $P{TELEFONE_EMPRESA} + "   " : "") +
                    ($P{EMAIL_EMPRESA} != null && !$P{EMAIL_EMPRESA}.isEmpty() ? $P{EMAIL_EMPRESA} + "\n" : "\n") +
                    ($P{CNPJ_EMPRESA} != null && !$P{CNPJ_EMPRESA}.isEmpty() ? "CNPJ: " + $P{CNPJ_EMPRESA} : "")
                ]]></textFieldExpression>
            </textField>

