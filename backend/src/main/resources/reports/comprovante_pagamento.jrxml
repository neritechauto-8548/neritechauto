                    <font size="16" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOME_EMPRESA} != null ? $P{NOME_EMPRESA}.toUpperCase() : "EMPRESA"]]></textFieldExpression>
