    <!-- ═══════════════ PAGE FOOTER ═══════════════ -->
    <pageFooter>
        <band height="20" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#666666" uuid="e5658932-d932-4d31-8854-463206234664"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
