<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="estoque"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              whenNoDataType="AllSectionsNoDetail"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="a1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d6">

    <!-- ═══════════════ PARAMETERS ═══════════════ -->
    <parameter name="NOME_EMPRESA" class="java.lang.String"/>
    <parameter name="CNPJ_EMPRESA" class="java.lang.String"/>
    <parameter name="TELEFONE_EMPRESA" class="java.lang.String"/>
    <parameter name="EMAIL_EMPRESA" class="java.lang.String"/>
    <parameter name="SITE_EMPRESA" class="java.lang.String"/>
    <parameter name="ENDERECO_EMPRESA" class="java.lang.String"/>
    <parameter name="DATA_EMISSAO" class="java.lang.String"/>
    <parameter name="VALOR_TOTAL_COMPRA" class="java.math.BigDecimal"/>
    <parameter name="VALOR_TOTAL_VENDA" class="java.math.BigDecimal"/>
    <parameter name="QUANTIDADE_TOTAL" class="java.lang.Long"/>
    <parameter name="LOGO_PATH" class="java.lang.String"/>

    <!-- ═══════════════ FIELDS ═══════════════ -->
    <field name="id" class="java.lang.Long"/>
    <field name="nomeProduto" class="java.lang.String"/>
    <field name="setor" class="java.lang.String"/>
    <field name="codigoOriginal" class="java.lang.String"/>
    <field name="codigoFab" class="java.lang.String"/>
    <field name="precoCusto" class="java.math.BigDecimal"/>
    <field name="precoVenda" class="java.math.BigDecimal"/>
    <field name="estoqueMinimo" class="java.lang.Integer"/>
    <field name="quantidade" class="java.lang.Integer"/>

    <variable name="ROW_NUM" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>

    <background>
        <band splitType="Stretch"/>
    </background>

    <!-- ═══════════════ TITLE / CABEÇALHO ═══════════════ -->
    <title>
        <band height="110" splitType="Stretch">
            <!-- Logo Section (Left Side) -->
            <image hAlign="Left" vAlign="Middle" onErrorType="Blank">
                <reportElement x="0" y="0" width="250" height="60" uuid="e1f2a3b4-c5d6-a1b2-c3d4-e5f6a7b8c9d0">
                    <printWhenExpression><![CDATA[$P{LOGO_PATH} != null && !$P{LOGO_PATH}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <!-- Company Details (Right Side / Left Aligned starting at x=350) -->
            <textField isBlankWhenNull="true">
                <reportElement x="350" y="0" width="452" height="60" uuid="a7b8c9d0-e1f2-a3b4-c5d6-a1b2c3d4e5f6"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    ($P{NOME_EMPRESA} != null ? $P{NOME_EMPRESA}.toUpperCase() + "\n" : "") +
                    ($P{TELEFONE_EMPRESA} != null && !$P{TELEFONE_EMPRESA}.equals("—") ? $P{TELEFONE_EMPRESA} + "\n" : "") +
                    ($P{EMAIL_EMPRESA} != null && !$P{EMAIL_EMPRESA}.equals("—") ? $P{EMAIL_EMPRESA} + "\n" : "") +
                    ($P{SITE_EMPRESA} != null && !$P{SITE_EMPRESA}.equals("—") ? $P{SITE_EMPRESA} + "\n" : "") +
                    ($P{ENDERECO_EMPRESA} != null && !$P{ENDERECO_EMPRESA}.equals("—") ? $P{ENDERECO_EMPRESA} : "")
                ]]></textFieldExpression>
            </textField>

            <!-- Horizontal Divider Line -->
            <line>
                <reportElement x="0" y="68" width="802" height="1" forecolor="#666666" uuid="c9d0e1f2-a3b4-c5d6-a7b8-c9d0e1f2a3b4"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Report Title -->
            <staticText>
                <reportElement x="0" y="75" width="802" height="25" uuid="5d858854-4632-9c32-e565-89320d316239"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="14" isBold="false"/>
                </textElement>
                <text><![CDATA[RELATÓRIO DE PRODUTOS]]></text>
            </staticText>
        </band>
    </title>

