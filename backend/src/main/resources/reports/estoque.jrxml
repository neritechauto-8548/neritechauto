    <!-- ═══════════════ DETAIL (ROWS) ═══════════════ -->
    <detail>
        <band height="20" splitType="Stretch">
            <!-- Cod -->
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="30" height="20" uuid="d9320623-8854-4d31-9c32-e56589324644"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
