                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOME_EMPRESA} != null ? $P{NOME_EMPRESA} : "NeriTech Auto"]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="5" width="202" height="15" forecolor="#999999" uuid="e5658932-d932-4d31-8854-463206234657"/>
