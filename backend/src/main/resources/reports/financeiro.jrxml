				<reportElement x="240" y="15" width="140" height="15" uuid="a1b2c3d4-e5f6-7890-abcd-000000000042"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="DejaVu Sans" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["A RECEBER = " + $P{A_RECEBER_TOTAL}]]></textFieldExpression>
