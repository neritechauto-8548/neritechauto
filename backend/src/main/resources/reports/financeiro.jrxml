			<textField>
				<reportElement x="0" y="15" width="230" height="15" uuid="a1b2c3d4-e5f6-7890-abcd-000000000038"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="DejaVu Sans" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["RECEITA (A RECEBER + RECEBIDOS) = " + $P{RECEITA_TOTAL}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="30" width="230" height="15" uuid="a1b2c3d4-e5f6-7890-abcd-000000000039"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
