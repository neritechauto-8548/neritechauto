					<font fontName="DejaVu Sans" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["PROVISIONAMENTO (RECEITA) - (DESPESA) = " + $P{PROVISIONAMENTO}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="60" width="230" height="15" uuid="a1b2c3d4-e5f6-7890-abcd-000000000041"/>
