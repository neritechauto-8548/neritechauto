<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="aniversariantes"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              whenNoDataType="AllSectionsNoDetail"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="15"
              bottomMargin="15"
              uuid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa">

    <parameter name="NOME_EMPRESA" class="java.lang.String">
        <defaultValueExpression><![CDATA["NeriTech Auto Center"]]></defaultValueExpression>
    </parameter>
    <parameter name="ENDERECO_EMPRESA" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="TELEFONE_EMPRESA" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="EMAIL_EMPRESA" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="CNPJ_EMPRESA" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="MES_REFERENCIA" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="DATA_EMISSAO" class="java.lang.String">
        <defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></defaultValueExpression>
    </parameter>

    <queryString><![CDATA[]]></queryString>
    <field name="nome" class="java.lang.String"/>
    <field name="dataNascimento" class="java.lang.String"/>

    <variable name="CONTADOR" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{nome}]]></variableExpression>
    </variable>

    <background>
        <band splitType="Stretch"/>
    </background>

    <!-- ============================================================
         TITLE — CABEÇALHO ESTILO ONMOTOR: LIMPO, PRETO E BRANCO
         ============================================================ -->
    <title>
        <band height="110" splitType="Stretch">

            <!-- Borda superior do cabeçalho -->
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000060"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </line>

            <!-- ===== COLUNA ESQUERDA: NOME + ENDEREÇO ===== -->
            <!-- Nome empresa (bold, grande) -->
            <textField>
                <reportElement x="0" y="4" width="310" height="18" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000004"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOME_EMPRESA}]]></textFieldExpression>
            </textField>

            <!-- Tagline -->
            <staticText>
                <reportElement x="0" y="22" width="310" height="12" forecolor="#444444" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000005"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isItalic="true"/>
                </textElement>
                <text><![CDATA[Sistema de Gestão para Oficinas Mecânicas]]></text>
            </staticText>

            <!-- Endereço -->
            <textField>
                <reportElement x="0" y="34" width="310" height="12" forecolor="#333333" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000006"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ENDERECO_EMPRESA}]]></textFieldExpression>
            </textField>

            <!-- ===== COLUNA CENTRAL: CONTATOS ===== -->
            <!-- Telefone -->
            <textField>
                <reportElement x="320" y="4" width="290" height="15" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000007"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TELEFONE_EMPRESA} != null && !$P{TELEFONE_EMPRESA}.isEmpty() ? $P{TELEFONE_EMPRESA} : ""]]></textFieldExpression>
            </textField>

            <!-- Email -->
            <textField>
                <reportElement x="320" y="20" width="290" height="13" forecolor="#333333" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000008"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{EMAIL_EMPRESA} != null && !$P{EMAIL_EMPRESA}.isEmpty() ? $P{EMAIL_EMPRESA} : ""]]></textFieldExpression>
            </textField>

            <!-- CNPJ -->
            <textField>
                <reportElement x="320" y="34" width="290" height="13" forecolor="#333333" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000009"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CNPJ_EMPRESA} != null && !$P{CNPJ_EMPRESA}.isEmpty() ? "CNPJ: " + $P{CNPJ_EMPRESA} : ""]]></textFieldExpression>
            </textField>

            <!-- ===== COLUNA DIREITA: SISTEMA ===== -->
            <staticText>
                <reportElement x="620" y="4" width="182" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000010"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[NeriTech Auto]]></text>
            </staticText>
            <staticText>
                <reportElement x="620" y="26" width="182" height="12" forecolor="#555555" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000050"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Gestão de Oficinas Mecânicas]]></text>
            </staticText>

            <!-- Borda inferior do cabeçalho -->
            <line>
                <reportElement x="0" y="50" width="802" height="1" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000061"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- ===== TÍTULO DO RELATÓRIO (fundo cinza claro) ===== -->
            <rectangle>
                <reportElement mode="Opaque" x="0" y="54" width="802" height="20" backcolor="#EEEEEE" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000051"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="54" width="600" height="20" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000011"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[RELATÓRIO DE ANIVERSARIANTES]]></text>
            </staticText>
            <textField>
                <reportElement x="600" y="54" width="202" height="20" forecolor="#333333" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000012"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Mês: " + $P{MES_REFERENCIA} + "  |  " + $P{DATA_EMISSAO}]]></textFieldExpression>
            </textField>
            <!-- Bordas do bloco título -->
            <line>
                <reportElement x="0" y="74" width="802" height="1" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000062"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- ===== CABEÇALHO DA TABELA (cinza mais escuro) ===== -->
            <rectangle>
                <reportElement mode="Opaque" x="0" y="78" width="802" height="22" backcolor="#DDDDDD" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000014"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <!-- Col Nº -->
            <staticText>
                <reportElement x="0" y="78" width="35" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000015"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Nº]]></text>
            </staticText>
            <line>
                <reportElement x="35" y="78" width="1" height="22" forecolor="#999999" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000016"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Col Nome -->
            <staticText>
                <reportElement x="36" y="78" width="320" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000017"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[   NOME DO CLIENTE]]></text>
            </staticText>
            <line>
                <reportElement x="356" y="78" width="1" height="22" forecolor="#999999" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000018"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Col Data Nasc -->
            <staticText>
                <reportElement x="357" y="78" width="130" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000019"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[DATA NASCIMENTO]]></text>
            </staticText>
            <line>
                <reportElement x="487" y="78" width="1" height="22" forecolor="#999999" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000020"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Col Idade -->
            <staticText>
                <reportElement x="488" y="78" width="80" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000021"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[IDADE]]></text>
            </staticText>
            <line>
                <reportElement x="568" y="78" width="1" height="22" forecolor="#999999" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000022"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Col Dia -->
            <staticText>
                <reportElement x="569" y="78" width="90" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000023"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[DIA ANIV.]]></text>
            </staticText>
            <line>
                <reportElement x="659" y="78" width="1" height="22" forecolor="#999999" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000024"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Col Status -->
            <staticText>
                <reportElement x="660" y="78" width="142" height="22" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000025"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[STATUS ENVIO]]></text>
            </staticText>

            <!-- Borda inferior cabeçalho tabela -->
            <line>
                <reportElement x="0" y="100" width="802" height="1" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000063"/>
                <graphicElement><pen lineWidth="0.8"/></graphicElement>
            </line>

        </band>
    </title>

    <!-- ============================================================
         DETAIL — LINHAS DE DADOS
         ============================================================ -->
    <detail>
        <band height="20" splitType="Stretch">

            <!-- Nº -->
            <textField>
                <reportElement x="0" y="0" width="35" height="19" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000027"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{CONTADOR}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="35" y="0" width="1" height="19" forecolor="#CCCCCC" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000028"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Nome -->
            <textField isStretchWithOverflow="true">
                <reportElement x="36" y="0" width="320" height="19" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000029"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["   " + $F{nome}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="356" y="0" width="1" height="19" forecolor="#CCCCCC" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000030"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Data Nascimento -->
            <textField>
                <reportElement x="357" y="0" width="130" height="19" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000031"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[($F{dataNascimento} != null && !$F{dataNascimento}.isEmpty()) ? $F{dataNascimento} : "-"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="487" y="0" width="1" height="19" forecolor="#CCCCCC" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000032"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Idade -->
            <textField>
                <reportElement x="488" y="0" width="80" height="19" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000033"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[($F{dataNascimento} != null && $F{dataNascimento}.length() >= 4) ? String.valueOf(java.time.Year.now().getValue() - Integer.parseInt($F{dataNascimento}.substring(0,4))) + " anos" : "-"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="568" y="0" width="1" height="19" forecolor="#CCCCCC" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000034"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Dia aniversário -->
            <textField>
                <reportElement x="569" y="0" width="90" height="19" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000035"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[($F{dataNascimento} != null && $F{dataNascimento}.length() >= 10) ? "Dia " + $F{dataNascimento}.substring(8,10) : "-"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="659" y="0" width="1" height="19" forecolor="#CCCCCC" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000036"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>

            <!-- Status -->
            <staticText>
                <reportElement x="660" y="0" width="142" height="19" forecolor="#333333" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000037"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[_________________]]></text>
            </staticText>

            <!-- Separador linha -->
            <line>
                <reportElement x="0" y="19" width="802" height="1" forecolor="#DDDDDD" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000038"/>
                <graphicElement><pen lineWidth="0.3"/></graphicElement>
            </line>

        </band>
    </detail>

    <!-- ============================================================
         PAGE FOOTER
         ============================================================ -->
    <pageFooter>
        <band height="18">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#888888" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000044"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="0" y="3" width="300" height="13" forecolor="#555555" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000045"/>
                <textElement verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[NeriTech Auto — Sistema de Gestão para Oficinas Mecânicas]]></text>
            </staticText>
            <textField>
                <reportElement x="300" y="3" width="202" height="13" forecolor="#555555" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000046"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER} + " de " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="502" y="3" width="300" height="13" forecolor="#555555" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000047"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Emitido em: " + $P{DATA_EMISSAO}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ============================================================
         SUMMARY — TOTALIZADOR
         ============================================================ -->
    <summary>
        <band height="40" splitType="Stretch">
            <line>
                <reportElement x="0" y="5" width="802" height="1" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000039"/>
                <graphicElement><pen lineWidth="0.8"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="10" y="12" width="220" height="20" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000041"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total de aniversariantes no mês:]]></text>
            </staticText>
            <textField>
                <reportElement x="232" y="12" width="50" height="20" forecolor="#000000" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000042"/>
                <textElement verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{CONTADOR}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="400" y="12" width="392" height="20" forecolor="#666666" uuid="aaaaaaaa-aaaa-aaaa-aaaa-000000000043"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7" isItalic="true"/>
                </textElement>
                <text><![CDATA[* Documento gerado automaticamente pelo sistema NeriTech Auto.]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
