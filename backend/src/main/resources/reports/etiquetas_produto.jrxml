<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="etiquetas_produto"
              pageWidth="612"
              pageHeight="792"
              columnCount="3"
              columnWidth="188"
              columnSpacing="9"
              leftMargin="15"
              rightMargin="15"
              topMargin="36"
              bottomMargin="36"
              uuid="d1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d6">

    <queryString>
        <![CDATA[]]>
    </queryString>

    <field name="nomeProduto" class="java.lang.String"/>
    <field name="codigoBarrasStr" class="java.lang.String"/>
    <field name="codigoBarrasImg" class="java.io.InputStream"/>
    <field name="preco" class="java.math.BigDecimal"/>
    <field name="codigoProduto" class="java.lang.String"/>

    <detail>
        <band height="72" splitType="Stretch">
            <!-- Barcode Image -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle" isUsingCache="true">
                <reportElement x="5" y="8" width="95" height="30" uuid="f1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d9">
                    <printWhenExpression><![CDATA[$F{nomeProduto} != null && !$F{nomeProduto}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$F{codigoBarrasImg}]]></imageExpression>
            </image>

            <!-- Barcode Text Underneath (size 6) -->
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="38" width="95" height="10" uuid="e1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d8">
                    <printWhenExpression><![CDATA[$F{nomeProduto} != null && !$F{nomeProduto}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Center" verticalAlignment="Top">
                    <font fontName="DejaVu Sans" size="6"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{codigoBarrasStr}]]></textFieldExpression>
            </textField>

            <!-- Product Code (e.g. Cod:0000001) -->
            <textField isBlankWhenNull="true">
                <reportElement x="105" y="10" width="75" height="12" uuid="a1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d1">
                    <printWhenExpression><![CDATA[$F{nomeProduto} != null && !$F{nomeProduto}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" isBold="false"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{codigoProduto}]]></textFieldExpression>
            </textField>

            <!-- Price (e.g. R$ 642,98) -->
            <textField pattern="R$ #,##0.00" isBlankWhenNull="true">
                <reportElement x="105" y="22" width="75" height="14" uuid="b1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d0">
                    <printWhenExpression><![CDATA[$F{nomeProduto} != null && !$F{nomeProduto}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{preco}]]></textFieldExpression>
            </textField>

            <!-- Product Description (e.g. AMORTECEDOR) -->
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="50" width="175" height="12" uuid="c1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d2">
                    <printWhenExpression><![CDATA[$F{nomeProduto} != null && !$F{nomeProduto}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Left" verticalAlignment="Top">
                    <font fontName="DejaVu Sans" size="7" isBold="false"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nomeProduto}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
