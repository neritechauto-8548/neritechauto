# Variáveis de Ambiente - NeriTech Backend

# ============================================
# DATABASE CONFIGURATION
# ============================================
# URL de conexão com PostgreSQL
# Formato: jdbc:postgresql://host:port/database
DATABASE_URL=jdbc:postgresql://localhost:5432/neritech

# Usuário do banco de dados
DATABASE_USERNAME=postgres

# Senha do banco de dados
DATABASE_PASSWORD=your_password_here

# ============================================
# SPRING CONFIGURATION
# ============================================
# Profile ativo (dev, prod, test)
SPRING_PROFILES_ACTIVE=prod

# ============================================
# SECURITY / JWT CONFIGURATION
# ============================================
# Chave secreta para JWT (mínimo 256 bits / 32 caracteres)
# Gere uma chave segura usando: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-minimum-256-bits-long-change-this-in-production

# ============================================
# SERVER CONFIGURATION
# ============================================
# Porta do servidor (Render define automaticamente)
PORT=8080

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================
# Opções da JVM (para otimização de memória, etc)
# JAVA_OPTS=-Xmx512m -Xms256m
